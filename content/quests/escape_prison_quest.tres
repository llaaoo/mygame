[sub_resource type="Resource" id="InteractObjective_cell_lever"]
script = ExtResource("4_interact")
target_tag = "cell_lever"
description = "Pull the cell lever"
track_from_start = false

[sub_resource type="Resource" id="QuestStage_cell"]
script = ExtResource("2_stage")
stage_id = "open_cell"
title = "Open the cell"
objectives = Array[ExtResource("3_objective")]([SubResource("InteractObjective_cell_lever")])

[sub_resource type="Resource" id="InteractObjective_supply"]
script = ExtResource("4_interact")
target_tag = "escape_supply"
description = "Open the storage chest"
track_from_start = false

[sub_resource type="Resource" id="QuestStage_supply"]
script = ExtResource("2_stage")
stage_id = "find_supplies"
title = "Find supplies"
objectives = Array[ExtResource("3_objective")]([SubResource("InteractObjective_supply")])

[sub_resource type="Resource" id="KillObjective_guard"]
script = ExtResource("5_kill")
target_tag = "prison_guard"
description = "Defeat a guard"

[sub_resource type="Resource" id="QuestStage_guard"]
script = ExtResource("2_stage")
stage_id = "thin_patrol"
title = "Thin the patrol"
objectives = Array[ExtResource("3_objective")]([SubResource("KillObjective_guard")])

[resource]
script = ExtResource("1_quest")
quest_id = "escape_prison_001"
title = "Escape the Cell"
description = "A prisoner points you toward the first opening: pull the cell lever, raid the storage chest, defeat a guard, and use the lower gate."
stages = Array[ExtResource("2_stage")]([SubResource("QuestStage_cell"), SubResource("QuestStage_supply"), SubResource("QuestStage_guard")])
reward_experience = 50
